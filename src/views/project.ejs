<%- include('partials/header') %>

    <main>
        <!-- Project Title -->
        <h1>
            <%= project.title %>
        </h1>
        
        <% if (user && user.role_name==='admin' ) { %>
            <p><a href="/edit-project/<%= project.project_id %>">Edit Project</a></p>
        <% } %>


        <!-- Project Details -->
        <p><strong>Description:</strong>
            <%= project.description %>
        </p>

        <% if (user && user.role_name==='admin' ) { %>
            <p><a href="/assign-categories/<%= project.project_id %>">Edit Categories</a></p>
        <% } %>

        

        <p><strong>Date:</strong>
            <%= new Date(project.date).toLocaleDateString() %>
        </p>

        <p><strong>Location:</strong>
            <%= project.location %>
        </p>

        <!-- Organization Link -->
        <p>
            <strong>Organization:</strong>
            <a href="/organization/<%= project.organization_id %>">
                <%= project.organization_name %>
            </a>
        </p>

        <!-- ✅ ✅ ADD THIS SECTION HERE -->
        <h3>Categories</h3>

        <% if (categories && categories.length> 0) { %>
            <ul>
                <% categories.forEach(category=> { %>
                    <li>
                        <a href="/category/<%= category.category_id %>">
                            <%= category.name %>
                        </a>
                    </li>
                    <% }) %>
            </ul>
            <% } else { %>
                <p>No categories available.</p>
            <% } %>

    </main>

    <%- include('partials/footer') %>