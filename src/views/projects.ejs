<%- include('partials/header') %>

    <main>
        <h2>
            <%= title %>
        </h2>

        <ul>
            <% projects.forEach(project=> { %>
                <li>
                    <!-- Project Link -->
                    <a href="/project/<%= project.project_id %>">
                        <%= project.title %>
                    </a>

                    <!-- Organization Link -->
                    (
                    <a href="/organization/<%= project.organization_id %>">
                        <%= project.organization_name %></a>)

                    
                </li>
                <% }) %>
        </ul>

        <p><a href="/new-project">Add a New Service Project</a></p>

                    
    </main>

    <%- include('partials/footer') %>
        
        