<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>

        <p>Here are a few of our partner organizations:</p>

        <ul>
            <% organizations.forEach(organization=> { %>
                <li>
                    <img src="/images/<%= organization.logo_filename %>" alt="<%= organization.name %> logo"
                        width="80" height="100"><a href="/organization/<%= organization.organization_id %>">
                            <%= organization.name %>
                        </a>

                    <h2>
                        <%= organization.name %>
                    </h2>

                    <p>
                        <%= organization.description %>
                    </p>

                    <p><strong>Email:</strong>
                        <%= organization.contact_email %>
                    </p>
                </li>
                <% }); %>
        </ul>

        <% if (user && user.role_name==='admin' ) { %>
           <p><a href="/new-organization">Add New Organization</a></p>
        <% } %>
    </main>

<%- include('partials/footer') %>